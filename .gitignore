# Secrets — secrets.toml now contains the MongoDB Atlas URI, DO NOT commit.
# Manage prod values via Streamlit Cloud -> Settings -> Secrets instead.
.streamlit/secrets.toml

# Google service-account / API credentials — NEVER commit
gen-lang-client-*.json
service-account*.json
*-service-account.json
google-credentials*.json
*.pem
*.key

# Local SQLite database (responses)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
